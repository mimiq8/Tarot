<!DOCTYPE html>

<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AI Tarot</title>
<style>
body{background:#07050d;color:#e8dcc8;font-family:serif;display:flex;align-items:center;justify-content:center;min-height:100vh;margin:0;}
.panel{background:rgba(255,255,255,.05);border:1px solid rgba(201,168,76,.3);border-radius:16px;padding:40px;text-align:center;max-width:360px;}
h1{color:#c9a84c;font-size:32px;margin-bottom:20px;}
button{background:transparent;border:1px solid #c9a84c;color:#c9a84c;padding:14px 28px;border-radius:8px;cursor:pointer;font-size:14px;margin:8px;}
</style>
</head>
<body>
<div class="panel">
  <h1>AI Tarot</h1>
  <p style="margin-bottom:24px;color:#9b7e4a">カードを引いてください</p>
  <div id="btns"></div>
  <div id="result" style="margin-top:20px"></div>
</div>
<script src="cards.js"></script>
<script>
try {
  document.getElementById("btns").innerHTML =
    "<button onclick=\"draw(1)\">一枚引き</button>" +
    "<button onclick=\"draw(3)\">三枚引き</button>";

function draw(n) {
const shuffled = […CARDS].sort(() => Math.random() - 0.5);
const picked = shuffled.slice(0, n);
document.getElementById(“result”).innerHTML = picked.map(c =>
“<div style="margin:10px 0;padding:10px;border:1px solid rgba(201,168,76,.2);border-radius:8px;">” +
“<div style="color:#c9a84c;margin-bottom:6px;">” + c.name + “ “ + c.nameEn + “</div>” +
“<img src="” + c.image + “" style="width:80px;border-radius:6px;">” +
“<p style="font-size:11px;color:#a09080;margin-top:6px;">” + c.positive + “</p>” +
“</div>”
).join(””);
}
} catch(e) {
document.body.innerHTML += “<p style="color:red">Error: “ + e.message + “</p>”;
}
</script>

</body>
</html>
